# Central tag overrides for the Hyprland stack
# You can edit these values or let update-hyprland.sh manage them.
# Each module script reads its TAG from these environment variables if set.

HYPRLAND_TAG=v0.52.1
AQUAMARINE_TAG=v0.9.3
# Hyprland 0.52.1's hyprtester uses CProcess::setStdinFD, available on hyprutils main.
# Pin to main to avoid API mismatch build errors.
HYPRUTILS_TAG=main
HYPRLANG_TAG=v0.6.4
HYPRGRAPHICS_TAG=v0.1.6
HYPRWAYLAND_SCANNER_TAG=v0.4.5
HYPRLAND_PROTOCOLS_TAG=v0.6.4
HYPRLAND_QT_SUPPORT_TAG=v0.1.0
HYPRLAND_GUIUTILS_TAG=v0.1.4
WAYLAND_PROTOCOLS_TAG=1.45
# libxkbcommon >= 1.9.0 required; build from source when Debian's version is older.
LIBXKBCOMMON_TAG=xkbcommon-1.13.0
